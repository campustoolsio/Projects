{
  "name": "fullstack-desktop-app",
  "version": "1.0.0",
  "description": "Full Stack Desktop Application - Node.js Backend + React Frontend",
  "main": "public/electron.js",
  "homepage": "./",
  "author": "Campus Tools",
  "license": "MIT",
  "scripts": {
    "start-backend": "cd backend && npm start",
    "start-frontend": "cd frontend && npm start",
    "dev": "concurrently \"npm run start-backend\" \"npm run start-frontend\"",
    "build-frontend": "cd frontend && npm run build",
    "build-desktop": "npm run build-frontend && electron-builder --win --publish never",
    "build-portable": "npm run build-frontend && electron-builder --win --portable --publish never",
    "build-installer": "npm run build-frontend && electron-builder --win --nsis --publish never",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1"
  },
  "build": {
    "appId": "com.campustools.fullstackapp",
    "productName": "Full Stack App",
    "files": [
      "build/**/*",
      "backend/**/*",
      "public/electron.js",
      "public/preload.js",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "signingHashAlgorithms": [
        "sha256"
      ],
      "sign": null
    }
  }
}
